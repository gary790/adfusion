# ============================================
# AD FUSION - Environment Configuration
# Copy to .env and fill in real values
# ============================================

# --- Server ---
NODE_ENV=development
PORT=3000
API_BASE_URL=http://localhost:3000

# --- PostgreSQL ---
DB_HOST=localhost
DB_PORT=5432
DB_NAME=adfusion
DB_USER=adfusion
DB_PASSWORD=adfusion_secret
DATABASE_URL=postgres://adfusion:adfusion_secret@localhost:5432/adfusion

# --- Redis ---
REDIS_URL=redis://localhost:6379

# --- Authentication ---
JWT_SECRET=your-jwt-secret-min-32-chars-change-in-production
JWT_ACCESS_EXPIRY=7d
JWT_REFRESH_EXPIRY=30d
SESSION_SECRET=your-session-secret-min-32-chars-change-in-production

# --- Meta (Facebook) Marketing API ---
# Register at: https://developers.facebook.com/
# Required scopes: ads_management, ads_read, business_management, read_insights
META_APP_ID=your_meta_app_id
META_APP_SECRET=your_meta_app_secret
META_REDIRECT_URI=http://localhost:3000/api/auth/meta/callback
META_WEBHOOK_VERIFY_TOKEN=your_webhook_verify_token
META_API_VERSION=v21.0

# --- OpenAI (GPT-4o) ---
# Get key at: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-your-openai-api-key
OPENAI_MODEL=gpt-4o
OPENAI_MAX_TOKENS=4096

# --- Stripe (Billing) ---
# Get keys at: https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key
STRIPE_PUBLISHABLE_KEY=pk_test_your_stripe_publishable_key
STRIPE_WEBHOOK_SECRET=whsec_your_stripe_webhook_secret

# Stripe Price IDs (create in Stripe Dashboard → Products)
STRIPE_STARTER_PRICE_ID=price_starter_monthly
STRIPE_PROFESSIONAL_PRICE_ID=price_professional_monthly
STRIPE_ENTERPRISE_PRICE_ID=price_enterprise_monthly

# --- Encryption ---
ENCRYPTION_KEY=adfusion-32char-encryption-key!!
ENCRYPTION_IV=adfusion-iv-16ch

# --- CORS ---
CORS_ORIGIN=http://localhost:3000

# --- Logging ---
LOG_LEVEL=debug
LOG_FORMAT=combined

# --- Rate Limiting ---
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# --- Google Cloud (for deployment) ---
GCP_PROJECT_ID=your-gcp-project-id
GCP_REGION=us-central1
