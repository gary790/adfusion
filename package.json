{
  "name": "ad-fusion",
  "version": "1.0.0",
  "description": "AI-Powered Meta (Facebook) Ad Creator & Optimizer SaaS Platform — Multi-tenant with real-time insights, GPT-4o optimization, automated rules, and Stripe billing",
  "main": "dist/server.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/server.js",
    "dev": "ts-node-dev --respawn --transpile-only src/server.ts",
    "dev:watch": "ts-node-dev --respawn --transpile-only --watch src/ src/server.ts",
    "migrate": "psql $DATABASE_URL -f migrations/001_initial_schema.sql",
    "db:migrate": "psql $DATABASE_URL -f migrations/001_initial_schema.sql",
    "db:seed": "psql $DATABASE_URL -f seed.sql",
    "db:reset": "psql $DATABASE_URL -f migrations/001_initial_schema.sql && psql $DATABASE_URL -f seed.sql",
    "test": "jest --coverage --forceExit",
    "test:watch": "jest --watch",
    "test:unit": "jest tests/unit/ --forceExit",
    "test:integration": "jest tests/integration/ --forceExit",
    "lint": "eslint src/**/*.ts",
    "typecheck": "tsc --noEmit",
    "docker:build": "docker build -t ad-fusion .",
    "docker:up": "docker-compose up -d",
    "docker:down": "docker-compose down",
    "docker:logs": "docker-compose logs -f app",
    "docker:reset": "docker-compose down -v && docker-compose up -d",
    "jobs:start": "node dist/jobs/runner.js",
    "setup": "bash scripts/setup.sh",
    "deploy:gcp": "bash scripts/deploy-gcp.sh",
    "health": "curl -s http://localhost:3000/health | node -e \"process.stdin.on('data',d=>console.log(JSON.parse(d)))\"",
    "clean": "rm -rf dist/ node_modules/ coverage/"
  },
  "dependencies": {
    "express": "^4.21.0",
    "cors": "^2.8.5",
    "helmet": "^8.0.0",
    "compression": "^1.7.4",
    "morgan": "^1.10.0",
    "dotenv": "^16.4.5",
    "pg": "^8.13.0",
    "pg-pool": "^3.7.0",
    "redis": "^4.7.0",
    "jsonwebtoken": "^9.0.2",
    "bcryptjs": "^2.4.3",
    "express-rate-limit": "^7.4.0",
    "express-validator": "^7.2.0",
    "axios": "^1.7.7",
    "openai": "^4.67.0",
    "node-cron": "^3.0.3",
    "bull": "^4.16.0",
    "winston": "^3.14.2",
    "uuid": "^10.0.0",
    "crypto-js": "^4.2.0",
    "stripe": "^17.0.0",
    "zod": "^3.23.8",
    "date-fns": "^4.1.0",
    "lodash": "^4.17.21",
    "ioredis": "^5.4.1",
    "passport": "^0.7.0",
    "passport-local": "^1.0.0",
    "cookie-parser": "^1.4.6",
    "express-session": "^1.18.0",
    "connect-redis": "^7.1.1",
    "multer": "^1.4.5-lts.1",
    "sharp": "^0.33.5",
    "sanitize-html": "^2.13.0"
  },
  "devDependencies": {
    "typescript": "^5.6.0",
    "ts-node": "^10.9.2",
    "ts-node-dev": "^2.0.0",
    "@types/node": "^22.0.0",
    "@types/express": "^5.0.0",
    "@types/cors": "^2.8.17",
    "@types/compression": "^1.7.5",
    "@types/morgan": "^1.9.9",
    "@types/pg": "^8.11.10",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/bcryptjs": "^2.4.6",
    "@types/node-cron": "^3.0.11",
    "@types/uuid": "^10.0.0",
    "@types/crypto-js": "^4.2.2",
    "@types/lodash": "^4.17.10",
    "@types/passport": "^1.0.16",
    "@types/passport-local": "^1.0.38",
    "@types/cookie-parser": "^1.4.7",
    "@types/express-session": "^1.18.0",
    "@types/multer": "^1.4.12",
    "@types/sanitize-html": "^2.13.0",
    "jest": "^29.7.0",
    "ts-jest": "^29.2.0",
    "@types/jest": "^29.5.0",
    "eslint": "^9.0.0",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/your-org/ad-fusion"
  },
  "author": "Ad Fusion Team",
  "license": "MIT"
}
